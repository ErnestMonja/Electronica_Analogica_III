      "source": [
        "## 10- Resolución final del sistema:\n",
        "# 10.1- Se definieron algunas variables:\n",
        "R_T = R_total[0,12]\n",
        "C_T_n = C_total[0,12]*1e9\n",
        "R_p_final = RP[0,12]\n",
        "\n",
        "# 10.2- Se definió los valores de Impedancias de entrada y salida del sistema en [ohms]:\n",
        "R_L = 1000\n",
        "R_G = 50\n",
        "\n",
        "# 10.3- Se definió capacidad objetivo por rama (en [F]).\n",
        "C_target = (C_T_n * 1e-9) / 2.0  \n",
        "\n",
        "# 10.4- Se calcularon las resistencias reflejadas (R'_G y R'_L) siguiendo las formulas de arriba:\n",
        "Rg_p_target = 2.0 * R_T\n",
        "Rl_p_target = (2.0 * R_T * R_p_final) / (R_p_final - 2.0 * R_T)\n",
        "\n",
        "# 10.5- Se calcularon los coeficientes \"k\" usando las impedancias objetivo donde: k = sqrt(R_baja / R_alta)\n",
        "k_in = np.sqrt(R_G / Rg_p_target) \n",
        "k_out = np.sqrt(R_L / Rl_p_target)\n",
        "\n",
        "# 10.6- Utilizando las fórmulas analíticas exactas:\n",
        "C1_final = C_target / (1.0 - k_in)\n",
        "C2_final = C_target / k_in\n",
        "C3_final = C_target / (1.0 - k_out)\n",
        "C4_final = C_target / k_out\n",
        "\n",
        "# 10.7- Se convirtieron las capacidades a [pF]:\n",
        "C1_final_p = C1_final * 1e12\n",
        "C2_final_p = C2_final * 1e12\n",
        "C3_final_p = C3_final * 1e12\n",
        "C4_final_p = C4_final * 1e12\n",
        "\n",
        "# 10.8- Se imprimen los resultados:\n",
        "print(f\"--- Resultados del Acople para el diseño [1, 13] ---\")\n",
        "print(f\"Resistencia total (RT): {R_T:.2f} Ω\")\n",
        "print(f\"Resistencia de Pérdidas (Rp): {R_p_final:.2f} Ω\")\n",
        "print()\n",
